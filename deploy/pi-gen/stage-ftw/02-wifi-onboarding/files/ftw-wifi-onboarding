#!/bin/bash
# Runs once at boot via ftw-wifi-onboarding.service.
#
# Two outcomes:
#   (a) NetworkManager already has a live connection → mark the box
#       configured and exit. Nothing to do.
#   (b) No connection → launch wifi-connect, which brings up the
#       `ftw-setup` AP, serves the captive portal at 192.168.42.1,
#       accepts the user's WiFi creds via the portal form, writes
#       them to NM as a persistent connection, and exits once the
#       pi is associated to the user's network.
#
# Either way we touch a sentinel so the service doesn't run on every
# boot. Users who want to re-onboard (e.g. moved the pi to a new
# house) can either `rm /var/lib/ftw/wifi-configured && reboot` or
# use the factory-reset endpoint (future work).

set -euo pipefail

SENTINEL=/var/lib/ftw/wifi-configured
install -d -m 0755 "$(dirname "${SENTINEL}")"

# nmcli's connectivity check prints one of: none, portal, limited,
# full, unknown. "full" is the only state that means a usable route
# to the internet; the others all need user intervention or more
# time. `--wait 30` blocks up to 30 s for NM to settle on a state,
# so we don't race a slow DHCP lease.
state="$(nmcli -t -f CONNECTIVITY general status 2>/dev/null || echo unknown)"
if [ "${state}" = "full" ] || [ "${state}" = "limited" ]; then
    touch "${SENTINEL}"
    exit 0
fi

# Portal mode. --portal-ssid names the AP the user's phone/laptop
# sees. No passphrase — easier onboarding, and the portal is only up
# until the user submits creds. The UI path points at the unpacked
# balena React bundle installed in 01-run-chroot.sh.
/usr/local/sbin/wifi-connect \
    --portal-ssid    "ftw-setup" \
    --ui-directory   /usr/share/wifi-connect/ui \
    --activity-timeout 600

touch "${SENTINEL}"
