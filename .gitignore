/target
/release
*.redb
config.yaml
data/

# Go build artifacts
/go/bin/
/go/dist/
/dist/driver-repository/
*.test
*.out

# go/cmd/* binaries built straight into go/ (e.g. `go build ./cmd/ftw-relay`).
# These are dev build outputs, never shipped — releases build into bin/ via
# the Makefile / release-assets workflow. Keep this list in sync with go/cmd/.
/go/forty-two-watts
/go/ftw
/go/ftw-pair
/go/ftw-relay
/go/ftw-updater
/go/sim-ferroamp
/go/sim-sungrow
# Windows build outputs of the same commands (`go build` adds .exe on Windows).
/go/*.exe

# Local config for simulators
config.local.yaml

# Local dev playground — state.db + config.local.yaml + logs seeded by
# `ftw -backfill N`. Per-machine, nothing here is shipped.
dev-data/

# Local dev env overrides (proxy upstream, dev toggles) — not shipped.
.env.local

# Per-user Claude Code harness settings — machine-local.
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Per-user Claude Code worktrees — machine-local, never tracked.
.claude/worktrees/

# Per-user Codex CLI tooling — machine-local, not part of the project.
.codex/

# pi-gen image builder — cloned by deploy/pi-gen/build.sh into the
# deploy/pi-gen/ subtree, plus the per-build copies of files that
# the stage pulls from the repo root at build time.
/deploy/pi-gen/pi-gen/
/deploy/pi-gen/stage-ftw/01-ftw-setup/files/docker-compose.yml
/deploy/pi-gen/stage-ftw/01-ftw-setup/files/mosquitto.conf

# State DB
*.db
*.db-journal
*.db-wal
*.db-shm
bin/
artifacts/
.cache/

# Changesets / Node — devtool surface only. package.json + the
# committed package-lock.json are tracked (reproducible installs in
# CI via `npm ci`); node_modules and runtime artifacts are not.
node_modules/
release-notes.md
optimizer/.venv/
optimizer/.pytest_cache/
optimizer/**/__pycache__/

# TLS material — never commit. Public certs go on the deploy host, private keys never leave the browser.
*.pem
*.crt
*.key
deploy/secrets/*
!deploy/secrets/README.md

# superpowers brainstorm visual companion (local only)
.superpowers/

# Goalbuddy renders local review boards; keep the markdown/state, not the
# generated static board assets.
docs/**/.goalbuddy-board/
