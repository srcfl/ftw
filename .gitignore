/target
/release
*.redb
config.yaml
data/

# Go build artifacts
/go/bin/
/go/dist/
*.test
*.out

# Local config for simulators
config.local.yaml

# Local dev playground — state.db + config.local.yaml + logs seeded by
# `forty-two-watts -backfill N`. Per-machine, nothing here is shipped.
dev-data/

# Local dev env overrides (proxy upstream, dev toggles) — not shipped.
.env.local

# Per-user Claude Code harness settings — machine-local.
.claude/settings.local.json

# Per-user Claude Code worktrees — machine-local, never tracked.
.claude/worktrees/

# pi-gen image builder — cloned by deploy/pi-gen/build.sh into the
# deploy/pi-gen/ subtree, plus the per-build copies of files that
# the stage pulls from the repo root at build time.
/deploy/pi-gen/pi-gen/
/deploy/pi-gen/stage-42w/01-ftw-setup/files/docker-compose.yml
/deploy/pi-gen/stage-42w/01-ftw-setup/files/mosquitto.conf

# State DB
*.db
*.db-journal
*.db-wal
*.db-shm
/go/sim-ferroamp
/go/sim-sungrow
/go/forty-two-watts
bin/
artifacts/
.cache/

# Changesets / Node — devtool surface only. package.json + the
# committed package-lock.json are tracked (reproducible installs in
# CI via `npm ci`); node_modules and runtime artifacts are not.
node_modules/
release-notes.md

# TLS material — never commit. Public certs go on the deploy host, private keys never leave the browser.
*.pem
*.crt
*.key
deploy/secrets/*
!deploy/secrets/README.md
